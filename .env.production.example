# Official public landing-site values for the July 2026 referral sprint.
# Configure these on the landing deployment host, then rebuild/redeploy.

NEXT_PUBLIC_APP_BASE_URL=https://medexia-akt.com

NEXT_PUBLIC_CONSENT_BANNER_ENABLED=true
NEXT_PUBLIC_CONSENT_VERSION=2026-06-23-v1
NEXT_PUBLIC_COOKIE_POLICY_URL=/cookies
NEXT_PUBLIC_PRIVACY_POLICY_URL=/privacy

# Leave pixels off until Meta/Google ids are configured and marketing-consent
# QA confirms scripts load only after explicit marketing consent.
NEXT_PUBLIC_ENABLE_MARKETING_PIXELS=false
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GOOGLE_ADS_ID=

# Growth Ledger persistence is not live unless this points at a real app/backend endpoint.
NEXT_PUBLIC_MARKETING_EVENTS_ENDPOINT=/api/marketing/events

# Official launch state: referral £49 copy is public only when a referral code is present.
NEXT_PUBLIC_REFERRAL_SPRINT_ENABLED=true
NEXT_PUBLIC_REFERRAL_FRIEND_DISCOUNT_ENABLED=true
