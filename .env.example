# Public landing-site defaults. These values are safe to commit.
# Real deployment values must be configured on the landing host and rebuilt.

NEXT_PUBLIC_APP_BASE_URL=https://medexia-akt.com

# Consent UX should remain on.
NEXT_PUBLIC_CONSENT_BANNER_ENABLED=true
NEXT_PUBLIC_CONSENT_VERSION=2026-06-23-v1
NEXT_PUBLIC_COOKIE_POLICY_URL=/cookies
NEXT_PUBLIC_PRIVACY_POLICY_URL=/privacy

# Keep third-party pixels off unless Meta/Google ids are configured and
# marketing-consent QA is complete.
NEXT_PUBLIC_ENABLE_MARKETING_PIXELS=false
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GOOGLE_ADS_ID=

# First-party landing events are validation-only unless pointed at a real backend.
NEXT_PUBLIC_MARKETING_EVENTS_ENDPOINT=/api/marketing/events

# Official July referral sprint: show £49 copy only when a referral code is present.
NEXT_PUBLIC_REFERRAL_SPRINT_ENABLED=true
NEXT_PUBLIC_REFERRAL_FRIEND_DISCOUNT_ENABLED=true
